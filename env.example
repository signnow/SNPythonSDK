# SignNow API Configuration
# Copy this file to .env and fill in your credentials
#
# To get your credentials:
# 1. Register for an account on SignNow: https://www.signnow.com/api
# 2. Create a new application
# 3. Obtain the Basic Authentication API token for your application
# 4. Fill in the values below

# SignNow API host (default: https://api.signnow.com)
SIGNNOW_API_HOST=https://api.signnow.com

# This is your application's Basic token from SignNow
SIGNNOW_API_BASIC_TOKEN=your_basic_token_here

# Your SignNow account email and password
SIGNNOW_API_USERNAME=your_email@example.com
SIGNNOW_API_PASSWORD=your_password_here

# Directory where downloaded files will be saved
SIGNNOW_DOWNLOADS_DIR=./downloads
